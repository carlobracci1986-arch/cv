# AI Provider Configuration
# Istruzioni:
# 1. Copia questo file in .env
# 2. Scegli un provider: 'claude', 'gemini', o 'openrouter'
# 3. Ottieni l'API key dal provider scelto
# 4. NON committare il file .env su git

# Provider selezionato: 'claude', 'gemini', o 'openrouter'
VITE_AI_PROVIDER=claude

# Anthropic Claude API (CONSIGLIATO)
# Ottieni API key da: https://console.anthropic.com
# Questo è il provider predefinito e consigliato per la migliore qualità
VITE_ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Google Gemini API
# Ottieni API key da: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=AIzaSyD...

# OpenRouter API
# Ottieni API key da: https://openrouter.ai/keys
# Modello: openai/gpt-oss-120b:free (gratuito)
VITE_OPENROUTER_API_KEY=sk-or-v1-...
